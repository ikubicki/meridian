{
	"name": "phpbb/phpbb",
	"description": "phpBB Forum Software application",
	"type": "project",
	"keywords": ["phpbb", "forum"],
	"homepage": "https://www.phpbb.com",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "phpBB Limited",
			"email": "operations@phpbb.com",
			"homepage": "https://www.phpbb.com/go/authors"
		}
	],
	"support": {
		"issues": "https://tracker.phpbb.com",
		"forum": "https://www.phpbb.com/community/",
		"docs": "https://www.phpbb.com/support/docs/",
		"irc": "irc://irc.libera.chat/phpbb",
		"chat": "https://www.phpbb.com/support/chat/"
	},
	"scripts": {
		"post-update-cmd": "echo 'You MUST manually modify the clean-vendor-dir target in build/build.xml when adding or upgrading dependencies.'",
		"setup": "sh -lc '[ -f package.json ] || npm init -y >/dev/null; npm install --save-dev @redocly/cli'",
		"swagger": "node_modules/.bin/redocly bundle .maister/tasks/research/2026-04-20-rest-api-spec/spec/root.yaml -o .maister/tasks/research/2026-04-20-rest-api-spec/outputs/openapi.yaml",
		"swagger:lint": "@php -r \"$service = $argv[1] ?? ''; if ($service === '') { fwrite(STDERR, 'Usage: composer swagger:lint -- <service|root>'.PHP_EOL); exit(1); } if (!preg_match('/^[a-z0-9-]+$/', $service)) { fwrite(STDERR, 'Invalid service name.'.PHP_EOL); exit(1); } $file = '.maister/tasks/research/2026-04-20-rest-api-spec/spec/' . $service . '.yaml'; passthru('node_modules/.bin/redocly lint ' . escapeshellarg($file), $code); exit($code);\"",
		"swagger:build": "@swagger && node_modules/.bin/redocly lint .maister/tasks/research/2026-04-20-rest-api-spec/outputs/openapi.yaml",
		"test": "vendor/bin/phpunit --testsuite phpbb4",
		"test:e2e": "cd tests/e2e && npx playwright test",
		"test:e2e:ui": "cd tests/e2e && npx playwright test --ui",
		"test:all": ["@test", "@test:e2e"],
		"cs": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
		"cs:fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php",
		"cs:check": "@cs"
	},
	"replace": {
		"phpbb/phpbb-core": "self.version"
	},
	"require": {
		"php": "^8.4",
		"ext-json": "*",
		"ext-mbstring": "*",
		"bantu/ini-get-wrapper": "~1.0",
		"carlos-mg89/oauth": "^0.8.15",
		"firebase/php-jwt": "^7.0",
		"google/recaptcha": "~1.1",
		"guzzlehttp/guzzle": "^7.0",
		"marc1706/fast-image-size": "^1.1",
		"s9e/text-formatter": "^2.0",
		"symfony/config": "^8.0",
		"symfony/console": "^8.0",
		"symfony/dependency-injection": "^8.0",
		"symfony/event-dispatcher": "^8.0",
		"symfony/filesystem": "^8.0",
		"symfony/finder": "^8.0",
		"symfony/framework-bundle": "^8.0",
		"symfony/http-foundation": "^8.0",
		"symfony/http-kernel": "^8.0",
		"symfony/polyfill-intl-normalizer": "^1.23",
		"symfony/polyfill-mbstring": "^1.23",
		"symfony/process": "^8.0",
		"symfony/routing": "^8.0",
		"symfony/twig-bridge": "^8.0",
		"symfony/yaml": "^8.0",
		"twig/twig": "^3.0"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.0",
		"php-webdriver/webdriver": "~1.8",
		"phing/phing": "~2.4",
		"phpunit/phpunit": "^10.0",
		"squizlabs/php_codesniffer": "~3.4",
		"symfony/browser-kit": "^8.0",
		"symfony/css-selector": "^8.0",
		"symfony/dom-crawler": "^8.0"
	},
	"extra": {
		"branch-alias": {
			"dev-master": "3.3.x-dev"
		}
	},
	"autoload": {
		"psr-4": {
			"phpbb\\": "src/phpbb/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"phpbb\\Tests\\": "tests/phpbb/"
		}
	},
	"config": {
		"platform": {
			"php": "8.4"
		},
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
